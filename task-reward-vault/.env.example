# ============================================================
# task-reward-vault 環境變數範本
# 使用方式：cp .env.example .env，再填入真實值
#
# ⚠️  .env 已在 .gitignore 中排除，絕對不可提交至 Git
# ⚠️  SEPOLIA_PRIVATE_KEY 為高敏感資訊，外洩即代表錢包資產可被盜取
#     不可截圖、不可傳訊息、不可 hardcode 進任何程式碼
# ============================================================


# ────────────────────────────────────────────────
# RPC 節點
#
# 用途：Hardhat 部署合約時連接 Sepolia 測試網
# 申請：https://www.alchemy.com → Create App → Ethereum Sepolia
# 格式：https://eth-sepolia.g.alchemy.com/v2/<YOUR_API_KEY>
#
# 備用公共節點（速率有限，可能偶爾失敗）：
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# ────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here


# ────────────────────────────────────────────────
# 部署者私鑰（Deployer）
#
# 用途：Hardhat 用此私鑰簽署部署交易，部署者自動成為合約的 operator
# 格式：64 位 hex 字串，不含 0x 前綴
# 取得：MetaMask → 帳號詳情 → 匯出私鑰 → 移除開頭的 0x
#
# ⚠️  此私鑰對應的錢包將成為合約 operator，
#     部署後應與 go-service 的 APP_PLATFORM_OPERATOR_PRIVATE_KEY 使用同一把金鑰
# ⚠️  確保此錢包有足夠的 Sepolia ETH 支付 Gas（水龍頭：https://www.alchemy.com/faucets/ethereum-sepolia）
# ────────────────────────────────────────────────
SEPOLIA_PRIVATE_KEY=your_deployer_private_key_here_without_0x_prefix


# ────────────────────────────────────────────────
# 平台金庫錢包地址（Treasury）
#
# 用途：合約收取的平台手續費（fee_bps）將轉入此地址
# 格式：0x 開頭的以太坊地址
# 需與 go-service 的 APP_PLATFORM_TREASURY_ADDRESS 一致
# ────────────────────────────────────────────────
TREASURY_ADDRESS=0xYourTreasuryWalletAddressHere
