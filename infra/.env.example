# PostgreSQL — 對應 go-service 的 DB_USER / DB_PASS / DB_NAME
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=TASK

# 可選：覆蓋預設 port
# PG_PORT=5432
# REDIS_PORT=6379

# ────────────────────────────────────────────────
# 本機 GUI / CLI 工具連線資訊（本地開發用）
#
# [pgAdmin 4]
#   Host:     localhost
#   Port:     5432（或 PG_PORT 自訂值）
#   Username: POSTGRES_USER
#   Password: POSTGRES_PASSWORD
#   Database: POSTGRES_DB
#
# [pgcli]
#   安裝：pip install pgcli
#
#   參數格式：
#     pgcli -h localhost -p 5432 -u postgres -d TASK
#
#   URI 格式：
#     pgcli postgres://postgres:your_password_here@localhost:5432/TASK
#
#   常用指令：
#     \dt          列出所有 Table
#     \d <table>   查看欄位結構
#     exit / Ctrl+D  離開
# ────────────────────────────────────────────────
